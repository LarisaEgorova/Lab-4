{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Собрать C++ ядро",
            "type": "shell",
            "command": "python",
            "args": ["-c", "import sys; sys.path.insert(0,'python'); import core_runner; core_runner.compile_core(force=True)"],
            "options": { "cwd": "${workspaceFolder}" },
            "group": { "kind": "build", "isDefault": true },
            "problemMatcher": [],
            "detail": "Компиляция ядра (автопоиск компилятора g++/clang++/cl.exe)"
        },
        {
            "label": "Запустить интерфейс",
            "type": "shell",
            "command": "python",
            "args": ["main.py"],
            "options": { "cwd": "${workspaceFolder}/tasks" },
            "group": { "kind": "test", "isDefault": true }
        }
    ]
}
